# ── Secrets — NEVER commit ───────────────────────────────────────
.env
*.env
.env.local
.env.production

# ── Database data — bind mount on disk, never commit ─────────────
data/

# ── Python ───────────────────────────────────────────────────────
dataseeder/__pycache__/
dataseeder/*.pyc
dataseeder/*.pyo
dataseeder/.venv/
dataseeder/venv/
dataseeder/*.xlsx

# ── .NET backend ─────────────────────────────────────────────────
backend/bin/
backend/obj/
backend/*.user
backend/.vs/

# ── React frontend ───────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ── Docker ───────────────────────────────────────────────────────
